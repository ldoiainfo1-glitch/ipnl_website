SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
PORT=4000

# AWS S3 – general bucket
AWS_S3_BUCKET=your_s3_bucket_name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# AWS S3 – logos bucket (can be same or different bucket/credentials)
AWS_S3_LOGOS_BUCKET=your_s3_logos_bucket_name
AWS_S3_REGION=ap-south-1
AWS_S3_LOGOS_ACCESS_KEY_ID=your_aws_logos_access_key_id
AWS_S3_LOGOS_SECRET_ACCESS_KEY=your_aws_logos_secret_access_key
